[Unit]
Description=Lightld candidate data worker
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/lightld
ExecStart=/usr/bin/node --experimental-strip-types --use-env-proxy src/cli/run-candidate-worker-main.ts --strategy new-token-v1
Restart=always
RestartSec=5
User=lightld
EnvironmentFile=/etc/lightld.env
ReadWritePaths=/opt/lightld/state

[Install]
WantedBy=multi-user.target
