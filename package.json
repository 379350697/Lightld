{
  "name": "lightweight-live-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest",
    "run:strategy": "node --experimental-strip-types src/cli/run-strategy-cycle-main.ts",
    "run:daemon": "node --experimental-strip-types src/cli/run-live-daemon-main.ts",
    "run:execution": "node --experimental-strip-types src/cli/run-local-execution-main.ts",
    "run:signer": "node --experimental-strip-types src/cli/run-local-signer-main.ts",
    "show:status": "node --experimental-strip-types src/cli/show-runtime-status-main.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
